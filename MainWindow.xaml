<Window x:Class="MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BetterNTE · 绝区零启动器"
        MinWidth="1000" MinHeight="700"
        Width="1100" Height="750"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        Background="#0A0A0A"
        FontFamily="Segoe UI"
        Closed="Window_Closed">
    <Window.Resources>
        <!-- ═══ ZZZ Theme Color Palette ═══ -->
        <Color x:Key="Z_Background">#0A0A0A</Color>
        <Color x:Key="Z_Panel">#141414</Color>
        <Color x:Key="Z_Card">#1A1A1A</Color>
        <Color x:Key="Z_BorderDark">#2A2A2A</Color>
        <Color x:Key="Z_BorderLight">#3A3A3A</Color>
        <Color x:Key="Z_AccentPrimary">#E6FF00</Color>
        <Color x:Key="Z_AccentSecondary">#FF0055</Color>
        <Color x:Key="Z_AccentCyan">#00D4FF</Color>
        <Color x:Key="Z_TextPrimary">#FFFFFF</Color>
        <Color x:Key="Z_TextSecondary">#888888</Color>
        <Color x:Key="Z_TextMuted">#555555</Color>
        <Color x:Key="Z_StatusOn">#00FF88</Color>
        <Color x:Key="Z_StatusOff">#FF4444</Color>

        <!-- ═══ Brushes ═══ -->
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource Z_Background}" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource Z_Panel}" />
        <SolidColorBrush x:Key="AppForegroundBrush" Color="{StaticResource Z_TextPrimary}" />
        <SolidColorBrush x:Key="SecondaryForegroundBrush" Color="{StaticResource Z_TextSecondary}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Z_AccentPrimary}" />
        <SolidColorBrush x:Key="AccentSecondaryBrush" Color="{StaticResource Z_AccentSecondary}" />
        <SolidColorBrush x:Key="AccentCyanBrush" Color="{StaticResource Z_AccentCyan}" />
        <SolidColorBrush x:Key="InactiveBrush" Color="{StaticResource Z_TextMuted}" />
        <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource Z_StatusOff}" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource Z_BorderDark}" />
        <SolidColorBrush x:Key="RunningBrush" Color="{StaticResource Z_StatusOn}" />
        
        <!-- For code-behind compatibility -->
        <SolidColorBrush x:Key="AccentColor" Color="{StaticResource Z_AccentPrimary}" />
        <SolidColorBrush x:Key="SecondaryTextColor" Color="{StaticResource Z_TextSecondary}" />
        <SolidColorBrush x:Key="CardBorderColor" Color="{StaticResource Z_BorderDark}" />
        <SolidColorBrush x:Key="RunningColor" Color="{StaticResource Z_StatusOn}" />

        <!-- Background Grid Pattern -->
        <DrawingBrush x:Key="GridPatternBrush" Viewport="0,0,30,30" ViewportUnits="Absolute" TileMode="Tile">
            <DrawingBrush.Drawing>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="#151515" Thickness="1"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <LineGeometry StartPoint="0,0" EndPoint="30,0" />
                            <LineGeometry StartPoint="0,0" EndPoint="0,30" />
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <!-- Diagonal Hazard Stripes -->
        <DrawingBrush x:Key="DiagonalStripesBrush" Viewport="0,0,20,20" ViewportUnits="Absolute" TileMode="Tile">
            <DrawingBrush.Drawing>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="{StaticResource AccentBrush}" Thickness="2"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <LineGeometry StartPoint="0,20" EndPoint="20,0"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <!-- Scanline Effect Brush -->
        <DrawingBrush x:Key="ScanlineBrush" Viewport="0,0,10,4" ViewportUnits="Absolute" TileMode="Tile">
            <DrawingBrush.Drawing>
                <GeometryDrawing Brush="{StaticResource AccentCyanBrush}">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="0,0,10,1"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <!-- ═══ Task Card Style (ZZZ Chamfered) ═══ -->
        <Style x:Key="TaskCardStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}" />
            <Setter Property="Margin" Value="8" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <!-- Card Body -->
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="0">
                                <Border.Effect>
                                    <DropShadowEffect x:Name="glow" Color="#000000" BlurRadius="5" Opacity="0.5" ShadowDepth="2" />
                                </Border.Effect>
                                <Grid>
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    <!-- Top-left tech corner L -->
                                    <Path Data="M 0,10 L 0,0 L 10,0" Stroke="{StaticResource AccentBrush}" StrokeThickness="2" HorizontalAlignment="Left" VerticalAlignment="Top" Opacity="0" x:Name="TopLeftAccent"/>
                                    <!-- Bottom-right tech corner L -->
                                    <Path Data="M 10,10 L 10,0 L 0,0" Stroke="{StaticResource AccentBrush}" StrokeThickness="2" HorizontalAlignment="Right" VerticalAlignment="Bottom" Opacity="0" x:Name="BottomRightAccent" RenderTransformOrigin="0.5,0.5">
                                        <Path.RenderTransform>
                                            <RotateTransform Angle="180"/>
                                        </Path.RenderTransform>
                                    </Path>
                                </Grid>
                            </Border>
                            <!-- Chamfered corner cut illusion -->
                            <Polygon Points="100,0 100,15 85,0" Fill="{StaticResource AppBackgroundBrush}" HorizontalAlignment="Right" VerticalAlignment="Top" Stretch="None"/>
                            <Polyline x:Name="ChamferLine" Points="84,0 100,16" Stroke="{TemplateBinding BorderBrush}" StrokeThickness="1" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                            <Polygon x:Name="HoverStripes" Points="100,0 100,15 85,0" Fill="{StaticResource DiagonalStripesBrush}" HorizontalAlignment="Right" VerticalAlignment="Top" Stretch="None" Opacity="0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1F1F1F" />
                                <Setter TargetName="ChamferLine" Property="Stroke" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.03" Duration="0:0:0.1" />
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.03" Duration="0:0:0.1" />
                                        <ColorAnimation Storyboard.TargetName="glow" Storyboard.TargetProperty="Color" To="{StaticResource Z_AccentPrimary}" Duration="0:0:0.2" />
                                        <DoubleAnimation Storyboard.TargetName="glow" Storyboard.TargetProperty="Opacity" To="0.3" Duration="0:0:0.2" />
                                        <DoubleAnimation Storyboard.TargetName="glow" Storyboard.TargetProperty="BlurRadius" To="15" Duration="0:0:0.2" />
                                        <DoubleAnimation Storyboard.TargetName="TopLeftAccent" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.1" />
                                        <DoubleAnimation Storyboard.TargetName="BottomRightAccent" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.1" />
                                        <DoubleAnimation Storyboard.TargetName="HoverStripes" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.1" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.1" />
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.1" />
                                        <ColorAnimation Storyboard.TargetName="glow" Storyboard.TargetProperty="Color" To="#000000" Duration="0:0:0.3" />
                                        <DoubleAnimation Storyboard.TargetName="glow" Storyboard.TargetProperty="Opacity" To="0.5" Duration="0:0:0.3" />
                                        <DoubleAnimation Storyboard.TargetName="glow" Storyboard.TargetProperty="BlurRadius" To="5" Duration="0:0:0.3" />
                                        <DoubleAnimation Storyboard.TargetName="TopLeftAccent" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2" />
                                        <DoubleAnimation Storyboard.TargetName="BottomRightAccent" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2" />
                                        <DoubleAnimation Storyboard.TargetName="HoverStripes" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Click">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="0.95" To="1.03" Duration="0:0:0.1" />
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.95" To="1.03" Duration="0:0:0.1" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Start Button Style ═══ -->
        <Style x:Key="StartButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI Black"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Width" Value="160"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="btnBorder" Background="{TemplateBinding Background}" CornerRadius="0">
                                <Border.Effect>
                                    <DropShadowEffect x:Name="btnGlow" Color="#E6FF00" BlurRadius="15" Opacity="0.3" ShadowDepth="0"/>
                                </Border.Effect>
                                <Grid>
                                    <!-- Chamfered cut -->
                                    <Polygon Points="160,0 160,14 146,0" Fill="{StaticResource AppBackgroundBrush}" HorizontalAlignment="Right" VerticalAlignment="Top" Stretch="None"/>
                                    <Polyline Points="145,0 160,15" Stroke="#000000" StrokeThickness="1" HorizontalAlignment="Right" VerticalAlignment="Top" Opacity="0.5"/>
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <!-- Tech accent line -->
                                    <Path Data="M 0,48 L 160,48" Stroke="#000000" StrokeThickness="2" Opacity="0.3" VerticalAlignment="Bottom"/>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="PreviewMouseDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="0.94" Duration="0:0:0.05" />
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="0.94" Duration="0:0:0.05" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.1" />
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.1" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="btnGlow" Storyboard.TargetProperty="BlurRadius" To="25" Duration="0:0:0.15" />
                                        <DoubleAnimation Storyboard.TargetName="btnGlow" Storyboard.TargetProperty="Opacity" To="0.5" Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="btnGlow" Storyboard.TargetProperty="BlurRadius" To="15" Duration="0:0:0.2" />
                                        <DoubleAnimation Storyboard.TargetName="btnGlow" Storyboard.TargetProperty="Opacity" To="0.3" Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Browse Button Style ═══ -->
        <Style x:Key="BrowseButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI Black"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{StaticResource AccentCyanBrush}" />
                                <Setter Property="Foreground" Value="#000000" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ ScrollBar Styling ═══ -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{StaticResource CardBorderBrush}" Margin="2,0" CornerRadius="4" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ═══ Root Grid ═══ -->
    <Grid>
        <!-- Background Pattern -->
        <Rectangle Fill="{StaticResource GridPatternBrush}" />

        <!-- Vignette Overlay -->
        <Rectangle>
            <Rectangle.Fill>
                <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.5" RadiusX="0.7" RadiusY="0.7">
                    <GradientStop Color="#00000000" Offset="0.4" />
                    <GradientStop Color="#C0000000" Offset="1" />
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- Tech decoration lines -->
        <Path Data="M 0,80 L 60,80 L 90,110" Stroke="{StaticResource CardBorderBrush}" StrokeThickness="2" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="0,40,0,0" Opacity="0.6"/>
        <Path Data="M 0,0 L 20,0 L 40,20 L 40,0" Stroke="{StaticResource AccentCyanBrush}" StrokeThickness="1" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="8,-8,0,0" Opacity="0.4"/>

        <!-- ═══ MAIN LAYOUT: 2 rows (Content + Footer) ═══ -->
        <Grid Margin="12,0,12,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ── Row 0: Content Area (Left Panel + Right Artwork) ── -->
            <Grid Grid.Row="0" Margin="0,12,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="6*" />
                    <ColumnDefinition Width="4*" />
                </Grid.ColumnDefinitions>

                <!-- ── LEFT COLUMN: Status + Cards + Log ── -->
                <Border Grid.Column="0" Background="{StaticResource PanelBackgroundBrush}" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" Margin="0,0,8,0">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />   <!-- Status Bar -->
                            <RowDefinition Height="*" />       <!-- Task Cards -->
                            <RowDefinition Height="Auto" />    <!-- Log Header -->
                            <RowDefinition Height="180" />     <!-- Log Panel (fixed, always visible) -->
                        </Grid.RowDefinitions>

                        <!-- Status Bar -->
                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Polygon x:Name="StatusIndicator" Points="6,0 12,6 6,12 0,6" Fill="{StaticResource InactiveBrush}" Margin="0,0,12,0" />
                                <TextBlock x:Name="StatusText" Text="已停止" Foreground="{StaticResource AppForegroundBrush}" FontFamily="Segoe UI Black" FontSize="20" TextOptions.TextFormattingMode="Display" />
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock Text="PROCESS" Foreground="{StaticResource AccentCyanBrush}" FontFamily="Consolas" FontWeight="Bold" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Bottom"/>
                                <TextBlock x:Name="GameProcessText" Text="-" Foreground="{StaticResource AppForegroundBrush}" FontFamily="Consolas" FontSize="12" Margin="0,0,20,0" VerticalAlignment="Bottom"/>
                                <TextBlock Text="UPTIME" Foreground="{StaticResource AccentCyanBrush}" FontFamily="Consolas" FontWeight="Bold" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Bottom"/>
                                <TextBlock x:Name="RuntimeText" Text="00:00:00" Foreground="{StaticResource AppForegroundBrush}" FontFamily="Consolas" FontSize="12" VerticalAlignment="Bottom"/>
                            </StackPanel>
                        </Grid>

                        <!-- Tech divider -->
                        <Rectangle Grid.Row="0" Height="1" Fill="{StaticResource CardBorderBrush}" VerticalAlignment="Bottom" Margin="0,0,0,0"/>

                        <!-- Task Cards (2x3 Grid) -->
                        <Grid Grid.Row="1" Margin="-8,4,-8,4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Teleport -->
                            <Button x:Name="TeleportCard" Grid.Row="0" Grid.Column="0" Click="TeleportCard_Click" Style="{StaticResource TaskCardStyle}">
                                <StackPanel Margin="16" Width="90">
                                    <TextBlock Text="TP" FontFamily="Segoe UI Black" FontSize="26" Foreground="{StaticResource AccentCyanBrush}" HorizontalAlignment="Center" Margin="0,0,0,6" />
                                    <TextBlock Text="传送协议" FontSize="14" FontFamily="Segoe UI Black" Foreground="{StaticResource AppForegroundBrush}" HorizontalAlignment="Center" />
                                    <TextBlock x:Name="TeleportStateText" Text="OFF" FontFamily="Consolas" FontWeight="Bold" FontSize="12" Foreground="{StaticResource SecondaryForegroundBrush}" HorizontalAlignment="Center" Margin="0,4,0,0" />
                                    <Border x:Name="TeleportStatus" Height="3" Margin="0,8,0,0" Background="{StaticResource CardBorderBrush}" />
                                </StackPanel>
                            </Button>

                            <!-- Pickup -->
                            <Button x:Name="PickupCard" Grid.Row="0" Grid.Column="1" Click="PickupCard_Click" Style="{StaticResource TaskCardStyle}">
                                <StackPanel Margin="16" Width="90">
                                    <TextBlock Text="LOOT" FontFamily="Segoe UI Black" FontSize="26" Foreground="{StaticResource AccentCyanBrush}" HorizontalAlignment="Center" Margin="0,0,0,6" />
                                    <TextBlock Text="自动拾取" FontSize="14" FontFamily="Segoe UI Black" Foreground="{StaticResource AppForegroundBrush}" HorizontalAlignment="Center" />
                                    <TextBlock x:Name="PickupStateText" Text="OFF" FontFamily="Consolas" FontWeight="Bold" FontSize="12" Foreground="{StaticResource SecondaryForegroundBrush}" HorizontalAlignment="Center" Margin="0,4,0,0" />
                                    <Border x:Name="PickupStatus" Height="3" Margin="0,8,0,0" Background="{StaticResource CardBorderBrush}" />
                                </StackPanel>
                            </Button>

                            <!-- Skip -->
                            <Button x:Name="SkipCard" Grid.Row="0" Grid.Column="2" Click="SkipCard_Click" Style="{StaticResource TaskCardStyle}">
                                <StackPanel Margin="16" Width="90">
                                    <TextBlock Text="SKIP" FontFamily="Segoe UI Black" FontSize="26" Foreground="{StaticResource AccentSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,6" />
                                    <TextBlock Text="跳过剧情" FontSize="14" FontFamily="Segoe UI Black" Foreground="{StaticResource AppForegroundBrush}" HorizontalAlignment="Center" />
                                    <TextBlock x:Name="SkipStateText" Text="OFF" FontFamily="Consolas" FontWeight="Bold" FontSize="12" Foreground="{StaticResource SecondaryForegroundBrush}" HorizontalAlignment="Center" Margin="0,4,0,0" />
                                    <Border x:Name="SkipStatus" Height="3" Margin="0,8,0,0" Background="{StaticResource CardBorderBrush}" />
                                </StackPanel>
                            </Button>

                            <!-- Dismiss -->
                            <Button x:Name="DismissCard" Grid.Row="1" Grid.Column="0" Click="DismissCard_Click" Style="{StaticResource TaskCardStyle}">
                                <StackPanel Margin="16" Width="90">
                                    <TextBlock Text="CLR" FontFamily="Segoe UI Black" FontSize="26" Foreground="{StaticResource AccentCyanBrush}" HorizontalAlignment="Center" Margin="0,0,0,6" />
                                    <TextBlock Text="驱散清理" FontSize="14" FontFamily="Segoe UI Black" Foreground="{StaticResource AppForegroundBrush}" HorizontalAlignment="Center" />
                                    <TextBlock x:Name="DismissStateText" Text="OFF" FontFamily="Consolas" FontWeight="Bold" FontSize="12" Foreground="{StaticResource SecondaryForegroundBrush}" HorizontalAlignment="Center" Margin="0,4,0,0" />
                                    <Border x:Name="DismissStatus" Height="3" Margin="0,8,0,0" Background="{StaticResource CardBorderBrush}" />
                                </StackPanel>
                            </Button>

                            <!-- Close -->
                            <Button x:Name="CloseCard" Grid.Row="1" Grid.Column="1" Click="CloseCard_Click" Style="{StaticResource TaskCardStyle}">
                                <StackPanel Margin="16" Width="90">
                                    <TextBlock Text="EXIT" FontFamily="Segoe UI Black" FontSize="26" Foreground="{StaticResource AccentSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,6" />
                                    <TextBlock Text="自动关闭" FontSize="14" FontFamily="Segoe UI Black" Foreground="{StaticResource AppForegroundBrush}" HorizontalAlignment="Center" />
                                    <TextBlock x:Name="CloseStateText" Text="OFF" FontFamily="Consolas" FontWeight="Bold" FontSize="12" Foreground="{StaticResource SecondaryForegroundBrush}" HorizontalAlignment="Center" Margin="0,4,0,0" />
                                    <Border x:Name="CloseStatus" Height="3" Margin="0,8,0,0" Background="{StaticResource CardBorderBrush}" />
                                </StackPanel>
                            </Button>

                            <!-- Click -->
                            <Button x:Name="ClickCard" Grid.Row="1" Grid.Column="2" Click="ClickCard_Click" Style="{StaticResource TaskCardStyle}">
                                <StackPanel Margin="16" Width="90">
                                    <TextBlock Text="CLK" FontFamily="Segoe UI Black" FontSize="26" Foreground="{StaticResource AccentCyanBrush}" HorizontalAlignment="Center" Margin="0,0,0,6" />
                                    <TextBlock Text="自动连点" FontSize="14" FontFamily="Segoe UI Black" Foreground="{StaticResource AppForegroundBrush}" HorizontalAlignment="Center" />
                                    <TextBlock x:Name="ClickStateText" Text="OFF" FontFamily="Consolas" FontWeight="Bold" FontSize="12" Foreground="{StaticResource SecondaryForegroundBrush}" HorizontalAlignment="Center" Margin="0,4,0,0" />
                                    <Border x:Name="ClickStatus" Height="3" Margin="0,8,0,0" Background="{StaticResource CardBorderBrush}" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- Log Panel (Always Visible - No Expander) -->
                        <Rectangle Grid.Row="2" Height="1" Fill="{StaticResource CardBorderBrush}" Margin="0,4,0,0"/>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,6">
                            <Rectangle Width="3" Height="14" Fill="{StaticResource AccentSecondaryBrush}" Margin="0,0,8,0"/>
                            <TextBlock Text="// SYSTEM_LOGS" Foreground="{StaticResource AppForegroundBrush}" FontFamily="Segoe UI Black" FontSize="13" />
                        </StackPanel>

                        <Border Grid.Row="3" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" Background="#050505">
                            <Grid>
                                <!-- Scanline overlay -->
                                <Rectangle Opacity="0.08" Fill="{StaticResource ScanlineBrush}" />
                                <ListBox x:Name="LogListBox" 
                                         Background="Transparent" Foreground="{StaticResource AccentCyanBrush}"
                                         BorderThickness="0" Padding="8" FontFamily="Consolas" FontSize="11" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- ── RIGHT COLUMN: ZZZ Artwork ── -->
                <Grid Grid.Column="1" Margin="8,0,0,0">
                    <!-- Fallback gradient background -->
                    <Rectangle>
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#0D1420" Offset="0" />
                                <GradientStop Color="#1A0A1A" Offset="0.4" />
                                <GradientStop Color="#0D0D0D" Offset="1" />
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <!-- ZZZ Artwork Image (loaded at runtime) -->
                    <Image x:Name="ZZZArtworkImage" Stretch="UniformToFill" VerticalAlignment="Center" />

                    <!-- Bottom gradient overlay for readability -->
                    <Rectangle VerticalAlignment="Bottom" Height="100">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#00000000" Offset="0" />
                                <GradientStop Color="#CC000000" Offset="1" />
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <!-- Tech overlay elements -->
                    <Path Data="M 0,0 L 0,30" Stroke="{StaticResource AccentCyanBrush}" StrokeThickness="2" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="12,12,0,0" Opacity="0.5"/>
                    <Path Data="M 0,0 L 30,0" Stroke="{StaticResource AccentCyanBrush}" StrokeThickness="2" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="12,12,0,0" Opacity="0.5"/>
                    <Path Data="M 0,0 L 0,30" Stroke="{StaticResource AccentCyanBrush}" StrokeThickness="2" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,12,12,0" Opacity="0.5"/>
                    <Path Data="M 0,0 L 30,0" Stroke="{StaticResource AccentCyanBrush}" StrokeThickness="2" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,12,12,0" Opacity="0.5"/>

                    <!-- Bottom-left corner tech accent -->
                    <Path Data="M 0,0 L 0,20 L 20,0" Stroke="{StaticResource AccentSecondaryBrush}" StrokeThickness="2" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="12,0,0,12" Opacity="0.4"/>
                    <Path Data="M 0,0 L 0,20 L 20,0" Stroke="{StaticResource AccentSecondaryBrush}" StrokeThickness="2" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,12,12" Opacity="0.4"/>

                    <!-- Brand text -->
                    <TextBlock Text="ZENLESS ZONE ZERO" FontFamily="Segoe UI Black" FontSize="16" 
                               Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" HorizontalAlignment="Center"
                               RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <RotateTransform Angle="-90"/>
                        </TextBlock.RenderTransform>
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#E6FF00" BlurRadius="10" Opacity="0.3" ShadowDepth="0"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </Grid>
            </Grid>

            <!-- ── Row 1: Footer (Game Path + Start Button) ── -->
            <Border Grid.Row="1" Background="{StaticResource PanelBackgroundBrush}" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" Padding="12,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Footer Left: Game Path + Browse -->
                    <Grid Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="GAME_DIR" Foreground="{StaticResource AccentCyanBrush}" FontFamily="Consolas" FontWeight="Bold" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>

                        <Border Grid.Column="1" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" Background="#050505">
                            <TextBox x:Name="GamePathText" IsReadOnly="True" 
                                     Background="Transparent" 
                                     Foreground="{StaticResource AppForegroundBrush}"
                                     BorderThickness="0" Padding="8,8" FontSize="12" FontFamily="Consolas" />
                        </Border>

                        <Button x:Name="BrowseButton" Grid.Column="2" Content="BROWSE" Style="{StaticResource BrowseButtonStyle}"
                                Margin="8,0,0,0" Click="BrowseButton_Click" />
                    </Grid>

                    <!-- Footer Right: Start Button -->
                    <Button x:Name="StartButton" Grid.Column="1" Content="▶ START" Style="{StaticResource StartButtonStyle}"
                            Click="StartButton_Click" VerticalAlignment="Center" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>