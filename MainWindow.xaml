<Window x:Class="MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BetterNTE · 异环启动器"
        MinWidth="1000" MinHeight="600"
        Width="1400" Height="648"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="Transparent"
        FontFamily="Segoe UI"
        Closed="Window_Closed">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="0"
                      NonClientFrameEdges="None"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <Color x:Key="N_Accent">#00B8D4</Color>
        <Color x:Key="N_AccentPink">#E04080</Color>
        <Color x:Key="N_TextPrimary">#FFFFFF</Color>
        <Color x:Key="N_TextSecondary">#C0B8D0</Color>
        <Color x:Key="N_TextMuted">#807098</Color>
        <Color x:Key="N_StatusOn">#00E070</Color>
        <Color x:Key="N_StatusOff">#E05050</Color>

        <SolidColorBrush x:Key="PanelBg" Color="#B8181830" />
        <SolidColorBrush x:Key="PanelBorder" Color="#50405070" />
        <SolidColorBrush x:Key="CardBg" Color="#B0202040" />
        <SolidColorBrush x:Key="AppForegroundBrush" Color="{StaticResource N_TextPrimary}" />
        <SolidColorBrush x:Key="SecondaryForegroundBrush" Color="{StaticResource N_TextSecondary}" />
        <SolidColorBrush x:Key="AccentCyanBrush" Color="{StaticResource N_Accent}" />
        <SolidColorBrush x:Key="AccentSecondaryBrush" Color="{StaticResource N_AccentPink}" />
        <SolidColorBrush x:Key="InactiveBrush" Color="{StaticResource N_TextMuted}" />
        <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource N_StatusOff}" />
        <SolidColorBrush x:Key="RunningBrush" Color="{StaticResource N_StatusOn}" />
        <SolidColorBrush x:Key="AccentColor" Color="{StaticResource N_Accent}" />
        <SolidColorBrush x:Key="SecondaryTextColor" Color="{StaticResource N_TextSecondary}" />
        <SolidColorBrush x:Key="RunningColor" Color="{StaticResource N_StatusOn}" />
        <!-- alias for CardBorderBrush / CardBorderColor / CardBorderBrush -->
        <SolidColorBrush x:Key="CardBorderBrush" Color="#50405070" />
        <SolidColorBrush x:Key="CardBorderColor" Color="#50405070" />
        <!-- code-behind compat (unchanged names) -->
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource N_Accent}" />
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#60181830" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#60181830" />

        <Style x:Key="GlassPanel" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="TaskCardStyle" TargetType="Button">
            <Setter Property="Width" Value="96" />
            <Setter Property="Height" Value="78" />
            <Setter Property="Background" Value="{StaticResource CardBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="3" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#90404070" />
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentCyanBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WinCtrlBtn" TargetType="Button">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Background" Value="#25000000" />
            <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="0,4,0,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#50FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="WinCloseBtn" TargetType="Button" BasedOn="{StaticResource WinCtrlBtn}">
            <Setter Property="FontSize" Value="22" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C0402020" />
                    <Setter Property="Foreground" Value="#FF6060" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SmallBtn" TargetType="Button">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Background" Value="{StaticResource CardBg}" />
            <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,5" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{StaticResource AccentCyanBrush}" />
                                <Setter Property="Foreground" Value="#0A0A1A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StartBtn" TargetType="Button">
            <Setter Property="FontSize" Value="19" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Background" Value="{StaticResource AccentCyanBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="24,8" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#20C8E0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StartBtnStandalone" TargetType="Button">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Background" Value="{StaticResource AccentCyanBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="36,14" />
            <Setter Property="MinWidth" Value="140" />
            <Setter Property="Height" Value="56" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="12"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TranslateTransform />
                            </Border.RenderTransform>
                            <Border.Effect>
                                <DropShadowEffect Opacity="0.35" BlurRadius="15" ShadowDepth="3" Color="#000" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                                                             From="0" To="-6" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.ShadowDepth)"
                                                             From="3" To="10" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                                                             From="-6" To="0" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.ShadowDepth)"
                                                             From="10" To="3" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Maximize / Restore icon geometries -->
        <PathGeometry x:Key="MaximizeIcon">M1,1 h10 v10 h-10 Z</PathGeometry>
        <PathGeometry x:Key="RestoreIcon">M4,0 h8 v8 h-8 Z M0,4 h8 v8 h-8 Z</PathGeometry>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="Width" Value="5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{StaticResource CardBorderBrush}" Margin="1,0" CornerRadius="2" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Image x:Name="BackgroundImage" Stretch="UniformToFill">
            <Image.Effect>
                <BlurEffect Radius="6" />
            </Image.Effect>
        </Image>
        <Rectangle Fill="#80000000" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,6,8,0" Panel.ZIndex="10">
            <Button x:Name="MinimizeButton" Content="─" Style="{StaticResource WinCtrlBtn}" Click="MinimizeButton_Click" />
            <Button x:Name="MaximizeButton" Style="{StaticResource WinCtrlBtn}" Click="MaximizeButton_Click">
                <Path x:Name="MaximizeIconPath" Data="{StaticResource MaximizeIcon}" Stroke="White" StrokeThickness="1.2" Width="12" Height="12" Stretch="Uniform" />
            </Button>
            <Button x:Name="CloseButton" Content="×" Style="{StaticResource WinCloseBtn}" Click="CloseButton_Click" />
        </StackPanel>

        <Grid Margin="24,34,24,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Status -->
            <Border Grid.Row="0" Style="{StaticResource GlassPanel}" Padding="14,6" Margin="0,0,0,8" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal">
                    <Polygon x:Name="StatusIndicator" Points="6,0 12,6 6,12 0,6" Fill="{StaticResource InactiveBrush}" Margin="0,0,10,0" VerticalAlignment="Center" />
                    <TextBlock x:Name="StatusText" Text="已停止" Foreground="{StaticResource AppForegroundBrush}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
                    <TextBlock x:Name="GameProcessText" Text="" Foreground="{StaticResource SecondaryForegroundBrush}" FontSize="14" Margin="16,0,0,0" VerticalAlignment="Center" />
                    <TextBlock x:Name="RuntimeText" Text="" Foreground="{StaticResource SecondaryForegroundBrush}" FontSize="14" Margin="14,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Content row -->
            <Grid Grid.Row="2" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Function cards: 2×3 -->
                <Border Grid.Column="0" Style="{StaticResource GlassPanel}" Padding="10,8" Margin="0,0,8,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>

                        <Button x:Name="TeleportCard" Grid.Row="0" Grid.Column="0" Click="TeleportCard_Click" Style="{StaticResource TaskCardStyle}">
                            <StackPanel>
                                <TextBlock x:Name="TeleportMainLabel" Text="自动传送" FontSize="16" FontWeight="Bold" Foreground="{StaticResource AccentCyanBrush}" HorizontalAlignment="Center" />
                                <TextBlock x:Name="TeleportStateText" Text="OFF" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AppForegroundBrush}" HorizontalAlignment="Center" />
                                <Border x:Name="TeleportStatus" Height="2" Margin="8,3,8,0" Background="{StaticResource CardBorderBrush}" CornerRadius="1" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="PickupCard" Grid.Row="0" Grid.Column="1" Click="PickupCard_Click" Style="{StaticResource TaskCardStyle}">
                            <StackPanel>
                                <TextBlock x:Name="PickupMainLabel" Text="自动拾取" FontSize="16" FontWeight="Bold" Foreground="{StaticResource AccentCyanBrush}" HorizontalAlignment="Center" />
                                <TextBlock x:Name="PickupStateText" Text="OFF" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AppForegroundBrush}" HorizontalAlignment="Center" />
                                <Border x:Name="PickupStatus" Height="2" Margin="8,3,8,0" Background="{StaticResource CardBorderBrush}" CornerRadius="1" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="SkipCard" Grid.Row="1" Grid.Column="0" Click="SkipCard_Click" Style="{StaticResource TaskCardStyle}">
                            <StackPanel>
                                <TextBlock x:Name="SkipMainLabel" Text="跳过剧情" FontSize="16" FontWeight="Bold" Foreground="{StaticResource AccentCyanBrush}" HorizontalAlignment="Center" />
                                <TextBlock x:Name="SkipStateText" Text="OFF" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AppForegroundBrush}" HorizontalAlignment="Center" />
                                <Border x:Name="SkipStatus" Height="2" Margin="8,3,8,0" Background="{StaticResource CardBorderBrush}" CornerRadius="1" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="DismissCard" Grid.Row="1" Grid.Column="1" Click="DismissCard_Click" Style="{StaticResource TaskCardStyle}">
                            <StackPanel>
                                <TextBlock x:Name="DismissMainLabel" Text="驱散顾客" FontSize="16" FontWeight="Bold" Foreground="{StaticResource AccentCyanBrush}" HorizontalAlignment="Center" />
                                <TextBlock x:Name="DismissStateText" Text="OFF" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AppForegroundBrush}" HorizontalAlignment="Center" />
                                <Border x:Name="DismissStatus" Height="2" Margin="8,3,8,0" Background="{StaticResource CardBorderBrush}" CornerRadius="1" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="CloseCard" Grid.Row="2" Grid.Column="0" Click="CloseCard_Click" Style="{StaticResource TaskCardStyle}">
                            <StackPanel>
                                <TextBlock x:Name="CloseMainLabel" Text="关闭弹窗" FontSize="16" FontWeight="Bold" Foreground="{StaticResource AccentCyanBrush}" HorizontalAlignment="Center" />
                                <TextBlock x:Name="CloseStateText" Text="OFF" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AppForegroundBrush}" HorizontalAlignment="Center" />
                                <Border x:Name="CloseStatus" Height="2" Margin="8,3,8,0" Background="{StaticResource CardBorderBrush}" CornerRadius="1" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="ClickCard" Grid.Row="2" Grid.Column="1" Click="ClickCard_Click" Style="{StaticResource TaskCardStyle}">
                            <StackPanel>
                                <TextBlock x:Name="ClickMainLabel" Text="自动点击" FontSize="16" FontWeight="Bold" Foreground="{StaticResource AccentCyanBrush}" HorizontalAlignment="Center" />
                                <TextBlock x:Name="ClickStateText" Text="OFF" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AppForegroundBrush}" HorizontalAlignment="Center" />
                                <Border x:Name="ClickStatus" Height="2" Margin="8,3,8,0" Background="{StaticResource CardBorderBrush}" CornerRadius="1" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <!-- Log panel (auto-height matching cards, scroll) -->
                <Border Grid.Column="1" Style="{StaticResource GlassPanel}" Padding="12,6" Margin="8,0,0,0" MaxHeight="260" VerticalAlignment="Stretch">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Rectangle Width="3" Height="16" Fill="{StaticResource AccentSecondaryBrush}" Margin="0,0,7,0" VerticalAlignment="Center"/>
                            <TextBlock Text="日志" Foreground="{StaticResource AppForegroundBrush}" FontSize="16" FontWeight="Bold" />
                        </StackPanel>
                        <Border Grid.Row="1" Background="#40101020" BorderThickness="0" CornerRadius="4">
                            <ListBox x:Name="LogListBox" 
                                     Background="Transparent" Foreground="{StaticResource AccentCyanBrush}"
                                     BorderThickness="0" Padding="6" FontFamily="Consolas" FontSize="14" 
                                     ScrollViewer.VerticalScrollBarVisibility="Auto" />
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- Footer -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <!-- Game dir + path + browse in glass panel -->
                <Border Grid.Column="0" Style="{StaticResource GlassPanel}" Padding="16,10" Margin="0,0,10,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Background="#90183040" BorderThickness="0" CornerRadius="4" Padding="8,4" Margin="0,0,10,0">
                            <TextBlock Text="游戏目录" Foreground="{StaticResource AccentCyanBrush}" FontSize="16" FontWeight="Bold" />
                        </Border>
                        <Border Grid.Column="1" Background="#40101020" BorderThickness="0" CornerRadius="4" MinWidth="280" MaxWidth="500" Margin="0,0,10,0" HorizontalAlignment="Left">
                            <TextBox x:Name="GamePathText" IsReadOnly="True" 
                                     Background="Transparent" Foreground="{StaticResource AppForegroundBrush}"
                                     BorderThickness="0" Padding="10,6" FontSize="15" FontWeight="Bold" TextAlignment="Left" />
                        </Border>
                        <Button Grid.Column="2" x:Name="BrowseButton" Content="浏览" Style="{StaticResource SmallBtn}" Click="BrowseButton_Click" />
                    </Grid>
                </Border>
                <!-- Standalone start button -->
                <Button Grid.Column="1" x:Name="StartButton" Content="▶ 启动" 
                        Style="{StaticResource StartBtnStandalone}" Click="StartButton_Click" 
                        VerticalAlignment="Center" />
            </Grid>
        </Grid>
    </Grid>
</Window>